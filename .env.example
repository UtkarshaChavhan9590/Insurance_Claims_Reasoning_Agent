# Microsoft Foundry project endpoint
# e.g. https://<your-project>.api.azureml.ms
FOUNDRY_PROJECT_ENDPOINT=https://foundry1westus.services.ai.azure.com/api/projects/proj-default

# Model deployment name in your Foundry project
FOUNDRY_MODEL_DEPLOYMENT=gpt-4o

# Azure AI Search service endpoint
AZURE_SEARCH_ENDPOINT=https://foundry-serach-service.search.windows.net

# Connection ID for the Azure AI Search connection registered in your Foundry project.
# Find it in Foundry portal → Project settings → Connected resources → your Search service.
# Format: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.MachineLearningServices/workspaces/<ws>/connections/<name>
AZURE_SEARCH_CONNECTION_ID=

# Name of the search index (created by setup_knowledge_base.py)
AZURE_SEARCH_INDEX_NAME=insurance-policy-index

# Admin API key for the Search service — used by setup_knowledge_base.py to
# upload documents (data-plane write). If omitted, DefaultAzureCredential is
# used (requires Search Index Data Contributor RBAC role).
AZURE_SEARCH_ADMIN_KEY=

# Claims auto-approval threshold (INR). Claims below this amount with no
# fraud indicators are approved automatically without human review.
CLAIM_AUTO_APPROVE_LIMIT=2000
